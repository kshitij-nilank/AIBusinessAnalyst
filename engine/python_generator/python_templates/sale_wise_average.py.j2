"""Generated report script for {{ report_title }}."""

import pandas as pd
from google.cloud import bigquery
from openpyxl.styles import Font, PatternFill
from openpyxl.utils import get_column_letter


SQL_QUERY = r"""
{{ sql }}
"""

OUTPUT_FILENAME = "{{ output_filename }}"


def auto_adjust_column_widths(ws):
    for column_cells in ws.columns:
        max_length = 0
        column_letter = get_column_letter(column_cells[0].column)
        for cell in column_cells:
            max_length = max(max_length, len(str(cell.value or "")))
        ws.column_dimensions[column_letter].width = min(max_length + 2, 40)


def apply_header_style(ws):
    fill = PatternFill("solid", fgColor="1F4E78")
    font = Font(color="FFFFFF", bold=True)
    for cell in ws[1]:
        cell.fill = fill
        cell.font = font


def freeze_top_row(ws):
    ws.freeze_panes = "A2"


def apply_number_formats(ws):
    for row in ws.iter_rows(min_row=2):
        for cell in row:
            if isinstance(cell.value, (int, float)):
                cell.number_format = "#,##0.00"


def run_report():
    client = bigquery.Client()
    dataframe = client.query(SQL_QUERY).to_dataframe()
    with pd.ExcelWriter(OUTPUT_FILENAME, engine="openpyxl") as writer:
        dataframe.to_excel(writer, index=False, sheet_name="Sale Wise Average")
        ws = writer.book["Sale Wise Average"]
        apply_header_style(ws)
        freeze_top_row(ws)
        apply_number_formats(ws)
        auto_adjust_column_widths(ws)


if __name__ == "__main__":
    run_report()

